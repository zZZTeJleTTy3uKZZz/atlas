# =============================================================================
# Universal .gitignore for atlas-managed projects (Clients/Products/Tests)
# Source of truth: NP-005 Volna 4.5 — backup priority is code+configs, NOT data.
# =============================================================================

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
*.egg-info/
*.egg
htmlcov/
.coverage
.coverage.*
.hypothesis/

# ----------------------------------------------------------------------------
# Node / JS / TS
# ----------------------------------------------------------------------------
node_modules/
.next/
.nuxt/
.cache/
.parcel-cache/
*.tsbuildinfo
coverage/

# ----------------------------------------------------------------------------
# Build outputs
# ----------------------------------------------------------------------------
dist/
build/
out/
target/
*.exe
*.dll

# ----------------------------------------------------------------------------
# IDE / editor
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# Environment / secrets (NEVER commit)
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.envrc
*.pem
*.key
secrets.*

# ----------------------------------------------------------------------------
# Logs (per Дмитрий: не пушить)
# ----------------------------------------------------------------------------
*.log
*.log.*
logs/
log/

# ----------------------------------------------------------------------------
# Databases (per Дмитрий: не пушить)
# ----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.db-journal

# ----------------------------------------------------------------------------
# CSV / TXT — промежуточные данные (per Дмитрий: не пушить)
# ----------------------------------------------------------------------------
*.csv
*.tsv
*.txt
!requirements*.txt
!constraints*.txt
!CHANGELOG.txt
!LICENSE.txt
!README.txt

# ----------------------------------------------------------------------------
# Big JSON dumps / extraction outputs (per Дмитрий: не пушить)
# ВАЖНО: важные конфиги не задеваем — см. !-исключения ниже.
# ----------------------------------------------------------------------------
dump_*.json
dumps_*.json
out_*.json
output_*.json
tmp_*.json
cache_*.json
network_dump*.json
*_dump.json
*-dump.json
extracted_*.json
batch_*.json
scrape_*.json
parsed_*.json
har_*.json
*.har

# Force-include важные конфиги:
!package.json
!package-lock.json
!tsconfig.json
!tsconfig.*.json
!.mcp.json
!atlas.json
!manifest.json
!composer.json
!.eslintrc.json
!.prettierrc.json
!components.json
!biome.json
!playwright.config.*
!pyproject.toml
!bun.lockb
!pnpm-lock.yaml
!yarn.lock

# ----------------------------------------------------------------------------
# Output / data folders by convention (внутри проектов)
# ----------------------------------------------------------------------------
output/
outputs/
results/
artifacts/
data/raw/
data/cache/
data/dumps/
playwright_*.json
playwright-report/
test-results/

# ----------------------------------------------------------------------------
# Other temp / backup
# ----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.backup
*.old
*~
.~lock.*

# ----------------------------------------------------------------------------
# Notebooks intermediate
# ----------------------------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# OS-specific
# ----------------------------------------------------------------------------
$RECYCLE.BIN/
System Volume Information/

# ----------------------------------------------------------------------------
# Project-specific overrides
# Если в проекте `data/` нужно ВКЛЮЧИТЬ — добавь `!data/<file>` в .gitignore проекта.
# ----------------------------------------------------------------------------
